{
  "name": "capacitor-onnx-example",
  "version": "1.0.0",
  "private": true,
  "description": "E2E test app for capacitor-onnx plugin",
  "scripts": {
    "sync": "cap sync",
    "build:apk": "cd android && ./gradlew assembleDebug",
    "test:ios": "node test-e2e-ios.mjs",
    "test:ios:verbose": "node test-e2e-ios.mjs --verbose",
    "test:yolo-ios": "node test-e2e-yolo-ios.mjs",
    "test:android": "node test-e2e-android.mjs",
    "test:android:verbose": "node test-e2e-android.mjs --verbose",
    "test:yolo-android": "node test-e2e-yolo-android.mjs",
    "test:resume-ios": "node test-e2e-resume-ios.mjs",
    "test:resume-android": "node test-e2e-resume-android.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "dust-core-capacitor": "0.1.3",
    "dust-onnx-capacitor": "file:..",
    "dust-serve-capacitor": "0.1.12"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.1.0"
  }
}
